---
import { getCollection, render } from 'astro:content';
import Base from '@/layouts/Base.astro';
import ImageGallery from '@/components/ImageGallery.tsx';
import SchemaOrg from '@/components/SchemaOrg.astro';
import { siteConfig } from '@/config';
import { formatPrice, buildWhatsAppUrl } from '@/lib/utils';

export async function getStaticPaths() {
  const products = await getCollection('produtos');
  return products.map(product => ({
    params: { slug: product.data.slug },
    props: { product },
  }));
}

const { product } = Astro.props;
const { data } = product;
const { Content } = await render(product);

const whatsappUrl = buildWhatsAppUrl(siteConfig.whatsapp, data.whatsapp_msg);

const categoryLabels: Record<string, string> = {
  'mdf': 'MDF',
  'pinus': 'Pinus',
  'cortes': 'Cortes sob Medida',
  'acessorios': 'Acessórios',
};
---

<Base title={data.nome} description={data.descricao}>
  <SchemaOrg type="Product" product={{ nome: data.nome, descricao: data.descricao, preco: data.preco }} />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb -->
    <nav class="mb-6 text-sm">
      <ol class="flex items-center gap-2 text-dark-light/60">
        <li><a href="/" class="hover:text-sage transition-colors">Início</a></li>
        <li>/</li>
        <li><a href="/catalogo" class="hover:text-sage transition-colors">Catálogo</a></li>
        <li>/</li>
        <li class="text-dark font-medium">{data.nome}</li>
      </ol>
    </nav>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10" transition:name={`product-${data.slug}`}>
      <!-- Galeria -->
      <div>
        <ImageGallery images={data.imagens} productName={data.nome} client:visible />
      </div>

      <!-- Info -->
      <div>
        <span class="inline-block bg-sage/10 text-sage-dark text-sm font-medium px-3 py-1 rounded-full mb-3">
          {categoryLabels[data.categoria] || data.categoria}
        </span>
        <h1 class="font-heading text-3xl sm:text-4xl font-bold text-dark">{data.nome}</h1>
        <p class="mt-4 text-dark-light/80 leading-relaxed">{data.descricao}</p>

        <div class="mt-6 flex items-center gap-3">
          <svg class="w-5 h-5 text-dark-light/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
          </svg>
          <span class="text-sm text-dark-light/70">{data.dimensoes}</span>
        </div>

        <div class="mt-8 p-6 bg-white rounded-2xl shadow-sm">
          <div class="text-sm text-dark-light/60 mb-1">Preço</div>
          <div class="text-4xl font-bold text-gold">{formatPrice(data.preco)}</div>
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-6 w-full inline-flex items-center justify-center gap-2 bg-sage text-white px-6 py-3 rounded-full font-medium hover:bg-sage-dark transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Comprar pelo WhatsApp
          </a>
        </div>

        <div class="mt-8 prose prose-sm max-w-none text-dark-light/80 [&_h2]:font-heading [&_h2]:text-dark [&_h2]:text-xl [&_h2]:mt-6 [&_h2]:mb-3 [&_strong]:text-dark [&_li]:marker:text-sage">
          <Content />
        </div>
      </div>
    </div>
  </div>
</Base>
