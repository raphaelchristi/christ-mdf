---
import Base from '@/layouts/Base.astro';
import { siteConfig } from '@/config';
---

<Base title="Sobre" description="Conheça a Christ MDF — sua loja especializada em MDF, pinus e soluções para marcenaria.">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="max-w-3xl mx-auto">
      <h1 class="font-heading text-3xl sm:text-4xl font-bold text-dark text-center">Sobre a {siteConfig.name}</h1>

      <div class="mt-10 space-y-8">
        <div class="bg-white rounded-2xl p-8 shadow-sm animate-fade-in-up">
          <h2 class="font-heading text-2xl font-semibold text-dark mb-4">Quem Somos</h2>
          <p class="text-dark-light/80 leading-relaxed">
            A Christ MDF é uma loja especializada em chapas de MDF, madeira de pinus e soluções completas para
            marcenaria. Atendemos desde marceneiros profissionais até entusiastas do DIY que buscam materiais
            de qualidade para seus projetos. Nosso compromisso é oferecer os melhores produtos com atendimento
            personalizado e preços competitivos.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-sm animate-fade-in-up" style="animation-delay: 0.1s;">
          <h2 class="font-heading text-2xl font-semibold text-dark mb-4">Nossos Diferenciais</h2>
          <ul class="space-y-3 text-dark-light/80">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-sage mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span><strong class="text-dark">Corte CNC sob medida</strong> — Cortamos suas chapas com precisão milimétrica nas medidas exatas do seu projeto.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-sage mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span><strong class="text-dark">Variedade de espessuras</strong> — MDF de 3mm a 25mm, pinus em diversas dimensões.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-sage mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span><strong class="text-dark">Equipe especializada</strong> — Ajudamos a calcular material, otimizar cortes e escolher o produto certo.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-sage mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span><strong class="text-dark">Preço justo</strong> — Trabalhamos com margens competitivas para profissionais e consumidores finais.</span>
            </li>
          </ul>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-sm animate-fade-in-up" style="animation-delay: 0.2s;">
          <h2 class="font-heading text-2xl font-semibold text-dark mb-4">O que Oferecemos</h2>
          <p class="text-dark-light/80 leading-relaxed">
            Chapas de <strong class="text-dark">MDF cru e melamínico</strong> em diversas espessuras,
            <strong class="text-dark">tábuas e sarrafos de pinus</strong> aplainados e secos em estufa,
            serviço de <strong class="text-dark">corte CNC sob medida</strong>, além de acessórios como
            parafusos, colas, fitas de borda e ferragens. Tudo num só lugar.
          </p>
        </div>

        <div class="text-center animate-fade-in-up" style="animation-delay: 0.3s;">
          <a
            href="/catalogo"
            class="inline-flex items-center gap-2 bg-sage text-white px-8 py-3 rounded-full font-medium hover:bg-sage-dark transition-colors"
          >
            Ver Nossos Produtos
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>
