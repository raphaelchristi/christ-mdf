---
import Base from '@/layouts/Base.astro';
import { siteConfig } from '@/config';
---

<Base title="Sobre" description="Conheça a Christ MDF — fabricação de mesas, painéis e peças decorativas em MDF e pinus para festas e eventos.">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="max-w-3xl mx-auto">
      <h1 class="font-heading text-3xl sm:text-4xl font-bold text-dark text-center">Sobre a {siteConfig.name}</h1>

      <div class="mt-10 space-y-8">
        <div class="bg-white rounded-2xl p-8 shadow-sm animate-fade-in-up">
          <h2 class="font-heading text-2xl font-semibold text-dark mb-4">Quem Somos</h2>
          <p class="text-dark-light/80 leading-relaxed">
            A Christ MDF é especializada na fabricação de peças decorativas em MDF e pinus para festas e eventos.
            Produzimos mesas temáticas, painéis, cenários, conjuntos e peças personalizadas com acabamento profissional.
            Nosso objetivo é oferecer produtos de qualidade que transformam qualquer festa em um evento inesquecível.
          </p>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-sm animate-fade-in-up" style="animation-delay: 0.1s;">
          <h2 class="font-heading text-2xl font-semibold text-dark mb-4">Nossos Diferenciais</h2>
          <ul class="space-y-3 text-dark-light/80">
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-sage mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span><strong class="text-dark">Fabricação própria</strong> — Todas as peças são produzidas em nossa oficina com materiais de primeira qualidade.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-sage mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span><strong class="text-dark">Peças sob medida</strong> — Criamos peças personalizadas no tamanho e tema que você precisar.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-sage mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span><strong class="text-dark">Acabamento profissional</strong> — Corte CNC preciso, peças prontas para uso ou pintura.</span>
            </li>
            <li class="flex items-start gap-3">
              <svg class="w-5 h-5 text-sage mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <span><strong class="text-dark">Preços competitivos</strong> — Qualidade profissional direto da fábrica, sem intermediários.</span>
            </li>
          </ul>
        </div>

        <div class="bg-white rounded-2xl p-8 shadow-sm animate-fade-in-up" style="animation-delay: 0.2s;">
          <h2 class="font-heading text-2xl font-semibold text-dark mb-4">O que Fabricamos</h2>
          <p class="text-dark-light/80 leading-relaxed">
            <strong class="text-dark">Mesas temáticas</strong> (futebol, gamer, Mickey e mais),
            <strong class="text-dark">painéis decorativos</strong> (borboleta, arco com colunas, Mickey/Minnie),
            <strong class="text-dark">cenários</strong> (celeiro, moinho),
            <strong class="text-dark">conjuntos de mesas</strong> (orgânico, lua, ripado com painel fly),
            <strong class="text-dark">peças avulsas</strong> (colunas ampulheta, estantes, pergolados em pinus)
            e muito mais. Tudo em MDF e pinus de qualidade.
          </p>
        </div>

        <div class="text-center animate-fade-in-up" style="animation-delay: 0.3s;">
          <a
            href="/catalogo"
            class="inline-flex items-center gap-2 bg-sage text-white px-8 py-3 rounded-full font-medium hover:bg-sage-dark transition-colors"
          >
            Ver Nossos Produtos
          </a>
        </div>
      </div>
    </div>
  </section>
</Base>
