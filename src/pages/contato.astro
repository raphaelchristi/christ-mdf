---
import Base from '@/layouts/Base.astro';
import { siteConfig } from '@/config';
import { buildWhatsAppUrl } from '@/lib/utils';
---

<Base title="Contato" description="Entre em contato com a Christ MDF. Solicite um orçamento pelo WhatsApp.">
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="text-center mb-10">
      <h1 class="font-heading text-3xl sm:text-4xl font-bold text-dark">Fale Conosco</h1>
      <p class="mt-3 text-dark-light/70 max-w-2xl mx-auto">
        Solicite um orçamento ou tire suas dúvidas. Estamos prontos para atender!
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-10 max-w-5xl mx-auto">
      <!-- Info de Contato -->
      <div class="space-y-6">
        <div class="bg-white rounded-2xl p-6 shadow-sm animate-fade-in-up">
          <h2 class="font-heading text-xl font-semibold text-dark mb-4">Informações de Contato</h2>
          <ul class="space-y-4">
            <li class="flex items-start gap-3">
              <div class="w-10 h-10 bg-sage/10 rounded-full flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-sage" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
              </div>
              <div>
                <strong class="text-dark block">WhatsApp</strong>
                <span class="text-dark-light/70 text-sm">{siteConfig.whatsapp.replace('55', '+55 ').replace(/(\d{2})(\d{5})(\d{4})/, '($1) $2-$3')}</span>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-10 h-10 bg-sage/10 rounded-full flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-sage" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                </svg>
              </div>
              <div>
                <strong class="text-dark block">E-mail</strong>
                <span class="text-dark-light/70 text-sm">{siteConfig.email}</span>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-10 h-10 bg-sage/10 rounded-full flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-sage" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                </svg>
              </div>
              <div>
                <strong class="text-dark block">Instagram</strong>
                <a href={siteConfig.instagramUrl} target="_blank" rel="noopener noreferrer" class="text-sage hover:text-sage-dark text-sm transition-colors">
                  {siteConfig.instagram}
                </a>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-10 h-10 bg-sage/10 rounded-full flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-sage" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
              </div>
              <div>
                <strong class="text-dark block">Endereço</strong>
                <span class="text-dark-light/70 text-sm">{siteConfig.endereco}</span>
              </div>
            </li>
            <li class="flex items-start gap-3">
              <div class="w-10 h-10 bg-sage/10 rounded-full flex items-center justify-center shrink-0">
                <svg class="w-5 h-5 text-sage" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
              </div>
              <div>
                <strong class="text-dark block">Horário</strong>
                <span class="text-dark-light/70 text-sm">{siteConfig.horario}</span>
              </div>
            </li>
          </ul>
        </div>
      </div>

      <!-- Formulário via WhatsApp -->
      <div class="bg-white rounded-2xl p-6 shadow-sm animate-fade-in-up" style="animation-delay: 0.15s;">
        <h2 class="font-heading text-xl font-semibold text-dark mb-4">Solicite um Orçamento</h2>
        <p class="text-sm text-dark-light/60 mb-6">Preencha o formulário e você será direcionado ao WhatsApp com sua mensagem.</p>

        <form id="contact-form" class="space-y-4">
          <div>
            <label for="nome" class="block text-sm font-medium text-dark mb-1">Nome</label>
            <input
              type="text"
              id="nome"
              name="nome"
              required
              class="w-full px-4 py-2.5 rounded-lg border border-cream-dark bg-cream focus:outline-none focus:ring-2 focus:ring-sage/50 focus:border-sage transition-colors text-sm"
              placeholder="Seu nome"
            />
          </div>
          <div>
            <label for="tipo" class="block text-sm font-medium text-dark mb-1">O que precisa?</label>
            <select
              id="tipo"
              name="tipo"
              class="w-full px-4 py-2.5 rounded-lg border border-cream-dark bg-cream focus:outline-none focus:ring-2 focus:ring-sage/50 focus:border-sage transition-colors text-sm"
            >
              <option value="chapas-mdf">Chapas de MDF</option>
              <option value="pinus">Pinus / Madeira</option>
              <option value="corte-sob-medida">Corte sob Medida</option>
              <option value="acessorios">Acessórios</option>
              <option value="outro">Outro</option>
            </select>
          </div>
          <div>
            <label for="mensagem" class="block text-sm font-medium text-dark mb-1">Detalhes do Pedido</label>
            <textarea
              id="mensagem"
              name="mensagem"
              rows={4}
              class="w-full px-4 py-2.5 rounded-lg border border-cream-dark bg-cream focus:outline-none focus:ring-2 focus:ring-sage/50 focus:border-sage transition-colors text-sm resize-none"
              placeholder="Descreva o que precisa (medidas, quantidade, espessura, etc.)"
            ></textarea>
          </div>
          <button
            type="submit"
            class="w-full inline-flex items-center justify-center gap-2 bg-sage text-white px-6 py-3 rounded-full font-medium hover:bg-sage-dark transition-colors"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Enviar pelo WhatsApp
          </button>
        </form>
      </div>
    </div>
  </section>
</Base>

<script define:vars={{ phone: siteConfig.whatsapp }}>
  document.addEventListener('astro:page-load', () => {
    const form = document.getElementById('contact-form');
    form?.addEventListener('submit', (e) => {
      e.preventDefault();

      const formData = new FormData(e.target);
      const nome = formData.get('nome') || '';
      const tipo = formData.get('tipo') || '';
      const mensagem = formData.get('mensagem') || '';

      const text = `Olá! Meu nome é ${nome}.
Preciso de: ${tipo}
${mensagem ? `Detalhes: ${mensagem}` : ''}
Gostaria de solicitar um orçamento.`;

      const url = `https://wa.me/${phone}?text=${encodeURIComponent(text)}`;
      window.open(url, '_blank');
    });
  });
</script>
