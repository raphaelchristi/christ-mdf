---
import { formatPrice } from '@/lib/utils';
import ImagePlaceholder from './ImagePlaceholder.astro';

interface Props {
  nome: string;
  slug: string;
  categoria: string;
  preco: number;
  preco_sob_consulta?: boolean;
  descricao: string;
  imagem?: string;
  index?: number;
}

const { nome, slug, categoria, preco, preco_sob_consulta = false, descricao, imagem, index = 0 } = Astro.props;

const categoryLabels: Record<string, string> = {
  'mesas': 'Mesas',
  'paineis': 'Painéis',
  'cenarios': 'Cenários',
  'conjuntos': 'Conjuntos',
  'pecas': 'Peças Decorativas',
};
---

<a
  href={`/catalogo/${slug}`}
  class="group block bg-white rounded-2xl overflow-hidden shadow-sm hover:shadow-md transition-all duration-300 animate-fade-in-up"
  style={`animation-delay: ${index * 0.1}s;`}
  data-category={categoria}
  transition:name={`product-${slug}`}
>
  <div class="relative overflow-hidden">
    {imagem && imagem !== '/placeholder' ? (
      <img
        src={imagem}
        alt={nome}
        class="w-full aspect-[4/3] object-cover group-hover:scale-105 transition-transform duration-500"
        loading="lazy"
      />
    ) : (
      <ImagePlaceholder class="group-hover:scale-105 transition-transform duration-500" />
    )}
    <span class="absolute top-3 left-3 bg-sage/90 text-white text-xs font-medium px-3 py-1 rounded-full backdrop-blur-sm">
      {categoryLabels[categoria] || categoria}
    </span>
  </div>
  <div class="p-5">
    <h3 class="font-heading text-lg font-semibold text-dark group-hover:text-sage-dark transition-colors">
      {nome}
    </h3>
    <p class="mt-1 text-sm text-dark-light/70 line-clamp-2">{descricao}</p>
    <div class="mt-3 flex items-center justify-between">
      <span class="text-xl font-bold text-gold">
        {preco_sob_consulta ? 'Sob consulta' : formatPrice(preco)}
      </span>
      <span class="text-sm text-sage font-medium group-hover:translate-x-1 transition-transform inline-flex items-center gap-1">
        Ver Detalhes
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
        </svg>
      </span>
    </div>
  </div>
</a>
