---
import { siteConfig } from '@/config';
import { buildWhatsAppUrl } from '@/lib/utils';

const whatsappUrl = buildWhatsAppUrl(siteConfig.whatsapp, 'Olá! Vi o site e gostaria de saber mais sobre os produtos.');
---

<section class="relative overflow-hidden min-h-[85vh] flex items-center">
  <!-- Background com imagem de produto -->
  <div class="absolute inset-0">
    <img
      src="/imagens/conjunto-mesa-organico/conjunto-mesa-organico-mdf.png"
      alt=""
      class="w-full h-full object-cover object-center opacity-15"
    />
  </div>
  <div class="absolute inset-0 bg-gradient-to-br from-dark via-dark/95 to-sage-dark/80"></div>

  <!-- Decoração geométrica -->
  <div class="absolute top-20 right-10 w-72 h-72 border border-gold/10 rounded-full hidden lg:block"></div>
  <div class="absolute bottom-20 right-32 w-48 h-48 border border-sage/10 rounded-full hidden lg:block"></div>
  <div class="absolute top-40 right-40 w-24 h-24 bg-gold/5 rounded-full hidden lg:block"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 w-full">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
      <div>
        <span class="inline-block text-sage-light text-sm font-medium tracking-widest uppercase mb-4 animate-fade-in-up">
          Fabricação própria em MDF e Pinus
        </span>
        <h1
          class="font-heading text-4xl sm:text-5xl lg:text-6xl font-bold text-white leading-tight animate-fade-in-up"
          style="animation-delay: 0.1s;"
          transition:name="hero-title"
        >
          Peças que transformam sua <span class="text-gold">festa em arte</span>
        </h1>
        <p class="mt-6 text-lg text-white/70 leading-relaxed max-w-lg animate-fade-in-up" style="animation-delay: 0.2s;">
          Mesas temáticas, painéis, cenários e conjuntos decorativos. Tudo feito com carinho em Saquarema, RJ.
        </p>
        <div class="mt-8 flex flex-wrap gap-4 animate-fade-in-up" style="animation-delay: 0.3s;">
          <a
            href="/catalogo"
            class="inline-flex items-center px-8 py-3.5 bg-gold text-dark font-semibold rounded-full hover:bg-gold-light transition-colors"
          >
            Ver Produtos
          </a>
          <a
            href={whatsappUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-8 py-3.5 bg-white/10 text-white rounded-full font-medium hover:bg-white/20 backdrop-blur-sm transition-colors border border-white/20"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Fale Conosco
          </a>
        </div>

        <!-- Mini stats -->
        <div class="mt-12 flex gap-8 animate-fade-in-up" style="animation-delay: 0.4s;">
          <div>
            <div class="text-2xl font-bold text-gold">16+</div>
            <div class="text-xs text-white/50 mt-1">Produtos</div>
          </div>
          <div class="w-px bg-white/10"></div>
          <div>
            <div class="text-2xl font-bold text-gold">MDF</div>
            <div class="text-xs text-white/50 mt-1">& Pinus</div>
          </div>
          <div class="w-px bg-white/10"></div>
          <div>
            <div class="text-2xl font-bold text-gold">RJ</div>
            <div class="text-xs text-white/50 mt-1">Saquarema</div>
          </div>
        </div>
      </div>

      <!-- Showcase de produtos no lado direito -->
      <div class="hidden lg:block relative">
        <div class="relative w-full aspect-square max-w-md mx-auto">
          <div class="absolute top-0 right-0 w-64 h-64 rounded-2xl overflow-hidden shadow-2xl rotate-3 hover:rotate-0 transition-transform duration-500">
            <img src="/imagens/mesa-bola-futebol/mesa-bola-futebol.png" alt="Mesa Bola" class="w-full h-full object-cover bg-white" />
          </div>
          <div class="absolute bottom-8 left-0 w-56 h-56 rounded-2xl overflow-hidden shadow-2xl -rotate-6 hover:rotate-0 transition-transform duration-500">
            <img src="/imagens/mesa-controle-gamer/mesa-controle-gamer-mdf.png" alt="Mesa Gamer" class="w-full h-full object-cover bg-white" />
          </div>
          <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-48 h-48 rounded-2xl overflow-hidden shadow-2xl rotate-2 hover:rotate-0 transition-transform duration-500 z-10">
            <img src="/imagens/painel-borboleta/painel-borboleta-mdf.png" alt="Painel Borboleta" class="w-full h-full object-cover bg-white" />
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
